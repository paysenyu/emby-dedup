# Emby Server
EMBY_SERVER_URL=http://your-emby-server-ip:8096
EMBY_API_KEY=your_emby_api_key_here

# PostgreSQL
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=emby
DATABASE_USER=emby
DATABASE_PASSWORD=your_secure_password_here

# Flask
SECRET_KEY=change-me-to-a-random-string
DEBUG=false

# App
SYNC_INTERVAL_HOURS=6
LOG_LEVEL=INFO
LOG_DIR=/app/logs